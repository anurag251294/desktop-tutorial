{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "factoryName": {
            "type": "string"
        }
    },
    "resources": [
        {
            "name": "[concat(parameters('factoryName'), '/DS_Graph_Binary_Download')]",
            "type": "Microsoft.DataFactory/factories/datasets",
            "apiVersion": "2018-06-01",
            "properties": {
                "description": "Binary dataset for downloading files using pre-authenticated Graph API download URLs. Uses parameterized HTTP linked service.",
                "linkedServiceName": {
                    "referenceName": "LS_HTTP_Graph_Download",
                    "type": "LinkedServiceReference",
                    "parameters": {
                        "downloadUrl": {
                            "value": "@dataset().DownloadUrl",
                            "type": "Expression"
                        }
                    }
                },
                "annotations": ["graph-api", "binary", "download", "hydro-one-migration"],
                "parameters": {
                    "DownloadUrl": {
                        "type": "string",
                        "description": "Full pre-authenticated download URL from Microsoft Graph API"
                    }
                },
                "type": "Binary",
                "typeProperties": {
                    "location": {
                        "type": "HttpServerLocation"
                    }
                }
            },
            "dependsOn": []
        }
    ]
}
