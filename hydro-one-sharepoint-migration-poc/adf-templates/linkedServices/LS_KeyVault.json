{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "factoryName": {
            "type": "string",
            "metadata": {
                "description": "Name of the Azure Data Factory instance"
            }
        },
        "keyVaultName": {
            "type": "string",
            "metadata": {
                "description": "Name of the Azure Key Vault"
            }
        }
    },
    "resources": [
        {
            "name": "[concat(parameters('factoryName'), '/LS_AzureKeyVault')]",
            "type": "Microsoft.DataFactory/factories/linkedServices",
            "apiVersion": "2018-06-01",
            "properties": {
                "description": "Linked service to Azure Key Vault for storing SharePoint credentials and other secrets",
                "annotations": [
                    "security",
                    "credentials",
                    "hydro-one-migration"
                ],
                "type": "AzureKeyVault",
                "typeProperties": {
                    "baseUrl": "[concat('https://', parameters('keyVaultName'), '.vault.azure.net/')]"
                }
            }
        }
    ],
    "outputs": {
        "linkedServiceName": {
            "type": "string",
            "value": "LS_AzureKeyVault"
        }
    }
}
