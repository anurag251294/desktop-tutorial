{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "factoryName": {
            "type": "string",
            "metadata": {
                "description": "Name of the Azure Data Factory instance"
            }
        }
    },
    "resources": [
        {
            "name": "[concat(parameters('factoryName'), '/PL_Process_Subfolder')]",
            "type": "Microsoft.DataFactory/factories/pipelines",
            "apiVersion": "2018-06-01",
            "properties": {
                "description": "Pipeline to process files within a SharePoint subfolder via Microsoft Graph API. Lists folder children, filters to files only, and copies using pre-authenticated download URLs.",
                "activities": [
                    {
                        "name": "Get_FolderChildren",
                        "description": "List all children (files and subfolders) in the current folder via Graph API",
                        "type": "WebActivity",
                        "dependsOn": [],
                        "policy": {
                            "timeout": "0.00:10:00",
                            "retry": 3,
                            "retryIntervalInSeconds": 60,
                            "secureOutput": false,
                            "secureInput": true
                        },
                        "userProperties": [],
                        "typeProperties": {
                            "method": "GET",
                            "headers": {
                                "Authorization": {
                                    "value": "@concat('Bearer ', pipeline().parameters.AccessToken)",
                                    "type": "Expression"
                                }
                            },
                            "url": {
                                "value": "@concat('https://graph.microsoft.com/v1.0/drives/', pipeline().parameters.DriveId, '/items/', pipeline().parameters.FolderId, '/children?$top=999')",
                                "type": "Expression"
                            }
                        }
                    },
                    {
                        "name": "Filter_Files",
                        "description": "Filter Graph response to only file items (those with downloadUrl)",
                        "type": "Filter",
                        "dependsOn": [
                            {
                                "activity": "Get_FolderChildren",
                                "dependencyConditions": ["Succeeded"]
                            }
                        ],
                        "userProperties": [],
                        "typeProperties": {
                            "items": {
                                "value": "@activity('Get_FolderChildren').output.value",
                                "type": "Expression"
                            },
                            "condition": {
                                "value": "@contains(string(item()), '\"@microsoft.graph.downloadUrl\"')",
                                "type": "Expression"
                            }
                        }
                    },
                    {
                        "name": "ForEach_File",
                        "type": "ForEach",
                        "dependsOn": [
                            {
                                "activity": "Filter_Files",
                                "dependencyConditions": ["Succeeded"]
                            }
                        ],
                        "userProperties": [],
                        "typeProperties": {
                            "items": {
                                "value": "@activity('Filter_Files').output.value",
                                "type": "Expression"
                            },
                            "isSequential": false,
                            "batchCount": 10,
                            "activities": [
                                {
                                    "name": "Copy_File",
                                    "type": "Copy",
                                    "dependsOn": [],
                                    "policy": {
                                        "timeout": "0.00:30:00",
                                        "retry": 3,
                                        "retryIntervalInSeconds": 60,
                                        "secureOutput": false,
                                        "secureInput": false
                                    },
                                    "userProperties": [],
                                    "typeProperties": {
                                        "source": {
                                            "type": "BinarySource",
                                            "storeSettings": {
                                                "type": "HttpReadSettings",
                                                "requestMethod": "GET",
                                                "additionalHeaders": {
                                                    "value": "@concat('Authorization: Bearer ', pipeline().parameters.AccessToken)",
                                                    "type": "Expression"
                                                },
                                                "requestTimeout": "00:10:00"
                                            },
                                            "formatSettings": {
                                                "type": "BinaryReadSettings"
                                            }
                                        },
                                        "sink": {
                                            "type": "BinarySink",
                                            "storeSettings": {
                                                "type": "AzureBlobFSWriteSettings"
                                            }
                                        },
                                        "enableStaging": false
                                    },
                                    "inputs": [
                                        {
                                            "referenceName": "DS_Graph_Content_Download",
                                            "type": "DatasetReference",
                                            "parameters": {
                                                "ContentPath": {
                                                    "value": "@concat('/v1.0/drives/', pipeline().parameters.DriveId, '/items/', item().id, '/content')",
                                                    "type": "Expression"
                                                }
                                            }
                                        }
                                    ],
                                    "outputs": [
                                        {
                                            "referenceName": "DS_ADLS_Binary_Sink",
                                            "type": "DatasetReference",
                                            "parameters": {
                                                "ContainerName": {
                                                    "value": "@pipeline().parameters.ContainerName",
                                                    "type": "Expression"
                                                },
                                                "SiteName": {
                                                    "value": "@replace(pipeline().parameters.SiteUrl, '/sites/', '')",
                                                    "type": "Expression"
                                                },
                                                "LibraryName": {
                                                    "value": "@pipeline().parameters.LibraryName",
                                                    "type": "Expression"
                                                },
                                                "FolderPath": {
                                                    "value": "@pipeline().parameters.FolderRelativePath",
                                                    "type": "Expression"
                                                },
                                                "FileName": {
                                                    "value": "@item().name",
                                                    "type": "Expression"
                                                }
                                            }
                                        }
                                    ]
                                },
                                {
                                    "name": "Log_Success",
                                    "type": "SqlServerStoredProcedure",
                                    "dependsOn": [
                                        {
                                            "activity": "Copy_File",
                                            "dependencyConditions": ["Succeeded"]
                                        }
                                    ],
                                    "policy": {
                                        "timeout": "0.00:05:00",
                                        "retry": 2,
                                        "retryIntervalInSeconds": 30,
                                        "secureOutput": false,
                                        "secureInput": false
                                    },
                                    "userProperties": [],
                                    "typeProperties": {
                                        "storedProcedureName": "[[dbo].[usp_LogFileAudit]",
                                        "storedProcedureParameters": {
                                            "FileName": {
                                                "value": { "value": "@item().name", "type": "Expression" },
                                                "type": "String"
                                            },
                                            "SourcePath": {
                                                "value": { "value": "@concat(pipeline().parameters.SiteUrl, '/', pipeline().parameters.LibraryName, '/', pipeline().parameters.FolderRelativePath, '/', item().name)", "type": "Expression" },
                                                "type": "String"
                                            },
                                            "DestinationPath": {
                                                "value": { "value": "@concat(pipeline().parameters.ContainerName, '/', replace(pipeline().parameters.SiteUrl, '/sites/', ''), '/', pipeline().parameters.LibraryName, '/', pipeline().parameters.FolderRelativePath, '/', item().name)", "type": "Expression" },
                                                "type": "String"
                                            },
                                            "FileSizeBytes": {
                                                "value": { "value": "@item().size", "type": "Expression" },
                                                "type": "Int64"
                                            },
                                            "MigrationStatus": {
                                                "value": "Success",
                                                "type": "String"
                                            },
                                            "PipelineRunId": {
                                                "value": { "value": "@pipeline().RunId", "type": "Expression" },
                                                "type": "String"
                                            },
                                            "ErrorDetails": {
                                                "value": null,
                                                "type": "String"
                                            }
                                        }
                                    },
                                    "linkedServiceName": {
                                        "referenceName": "LS_AzureSqlDatabase",
                                        "type": "LinkedServiceReference"
                                    }
                                },
                                {
                                    "name": "Log_Failure",
                                    "type": "SqlServerStoredProcedure",
                                    "dependsOn": [
                                        {
                                            "activity": "Copy_File",
                                            "dependencyConditions": ["Failed"]
                                        }
                                    ],
                                    "policy": {
                                        "timeout": "0.00:05:00",
                                        "retry": 2,
                                        "retryIntervalInSeconds": 30,
                                        "secureOutput": false,
                                        "secureInput": false
                                    },
                                    "userProperties": [],
                                    "typeProperties": {
                                        "storedProcedureName": "[[dbo].[usp_LogFileAudit]",
                                        "storedProcedureParameters": {
                                            "FileName": {
                                                "value": { "value": "@item().name", "type": "Expression" },
                                                "type": "String"
                                            },
                                            "SourcePath": {
                                                "value": { "value": "@concat(pipeline().parameters.SiteUrl, '/', pipeline().parameters.LibraryName, '/', pipeline().parameters.FolderRelativePath, '/', item().name)", "type": "Expression" },
                                                "type": "String"
                                            },
                                            "DestinationPath": {
                                                "value": { "value": "@concat(pipeline().parameters.ContainerName, '/', replace(pipeline().parameters.SiteUrl, '/sites/', ''), '/', pipeline().parameters.LibraryName, '/', pipeline().parameters.FolderRelativePath)", "type": "Expression" },
                                                "type": "String"
                                            },
                                            "FileSizeBytes": {
                                                "value": { "value": "@item().size", "type": "Expression" },
                                                "type": "Int64"
                                            },
                                            "MigrationStatus": {
                                                "value": "Failed",
                                                "type": "String"
                                            },
                                            "PipelineRunId": {
                                                "value": { "value": "@pipeline().RunId", "type": "Expression" },
                                                "type": "String"
                                            },
                                            "ErrorDetails": {
                                                "value": { "value": "@activity('Copy_File').output.errors[0].Message", "type": "Expression" },
                                                "type": "String"
                                            }
                                        }
                                    },
                                    "linkedServiceName": {
                                        "referenceName": "LS_AzureSqlDatabase",
                                        "type": "LinkedServiceReference"
                                    }
                                }
                            ]
                        }
                    }
                ],
                "parameters": {
                    "SiteUrl": {
                        "type": "string"
                    },
                    "LibraryName": {
                        "type": "string"
                    },
                    "ContainerName": {
                        "type": "string",
                        "defaultValue": "sharepoint-migration"
                    },
                    "AccessToken": {
                        "type": "string"
                    },
                    "DriveId": {
                        "type": "string"
                    },
                    "FolderId": {
                        "type": "string"
                    },
                    "FolderRelativePath": {
                        "type": "string"
                    },
                    "SharePointTenantUrl": {
                        "type": "string",
                        "defaultValue": "https://m365x52073746.sharepoint.com"
                    }
                },
                "annotations": [
                    "recursive-subfolder",
                    "hydro-one-migration",
                    "graph-api"
                ],
                "folder": {
                    "name": "SharePoint Migration"
                }
            }
        }
    ]
}
