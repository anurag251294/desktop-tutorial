{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "factoryName": {
            "type": "string",
            "defaultValue": "adf-hydroone-migration-dev",
            "metadata": {
                "description": "Name of the Azure Data Factory instance"
            }
        },
        "location": {
            "type": "string",
            "defaultValue": "[resourceGroup().location]",
            "metadata": {
                "description": "Location for the Data Factory"
            }
        },
        "sharePointTenantUrl": {
            "type": "string",
            "defaultValue": "https://hydroone.sharepoint.com",
            "metadata": {
                "description": "SharePoint Online tenant URL"
            }
        },
        "servicePrincipalId": {
            "type": "string",
            "metadata": {
                "description": "Azure AD Application (Client) ID for SharePoint access"
            }
        },
        "tenantId": {
            "type": "string",
            "metadata": {
                "description": "Azure AD Tenant ID"
            }
        },
        "keyVaultName": {
            "type": "string",
            "metadata": {
                "description": "Name of the Azure Key Vault"
            }
        },
        "storageAccountName": {
            "type": "string",
            "metadata": {
                "description": "Name of the ADLS Gen2 Storage Account"
            }
        },
        "sqlServerName": {
            "type": "string",
            "metadata": {
                "description": "Name of the Azure SQL Server"
            }
        },
        "sqlDatabaseName": {
            "type": "string",
            "defaultValue": "MigrationControl",
            "metadata": {
                "description": "Name of the Azure SQL Database"
            }
        },
        "clientSecretSecretName": {
            "type": "string",
            "defaultValue": "sharepoint-client-secret",
            "metadata": {
                "description": "Name of the secret in Key Vault"
            }
        },
        "incrementalSyncStartTime": {
            "type": "string",
            "defaultValue": "2024-01-01T07:00:00Z",
            "metadata": {
                "description": "Start time for incremental sync (UTC) - 2 AM EST"
            }
        }
    },
    "variables": {
        "factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
    },
    "resources": [
        {
            "name": "[parameters('factoryName')]",
            "type": "Microsoft.DataFactory/factories",
            "apiVersion": "2018-06-01",
            "location": "[parameters('location')]",
            "identity": {
                "type": "SystemAssigned"
            },
            "properties": {
                "publicNetworkAccess": "Enabled"
            },
            "tags": {
                "Project": "Hydro One SharePoint Migration",
                "Environment": "POC",
                "CostCenter": "IT-Migration"
            }
        },
        {
            "name": "[concat(parameters('factoryName'), '/LS_AzureKeyVault')]",
            "type": "Microsoft.DataFactory/factories/linkedServices",
            "apiVersion": "2018-06-01",
            "dependsOn": [
                "[variables('factoryId')]"
            ],
            "properties": {
                "description": "Azure Key Vault for storing SharePoint credentials",
                "annotations": ["security", "credentials", "hydro-one-migration"],
                "type": "AzureKeyVault",
                "typeProperties": {
                    "baseUrl": "[concat('https://', parameters('keyVaultName'), '.vault.azure.net/')]"
                }
            }
        },
        {
            "name": "[concat(parameters('factoryName'), '/LS_SharePointOnline_REST')]",
            "type": "Microsoft.DataFactory/factories/linkedServices",
            "apiVersion": "2018-06-01",
            "dependsOn": [
                "[variables('factoryId')]",
                "[concat(variables('factoryId'), '/linkedServices/LS_AzureKeyVault')]"
            ],
            "properties": {
                "description": "REST linked service for SharePoint Online API calls",
                "annotations": ["sharepoint", "source", "rest-api", "hydro-one-migration"],
                "type": "RestService",
                "typeProperties": {
                    "url": "[concat(parameters('sharePointTenantUrl'), '/_api')]",
                    "enableServerCertificateValidation": true,
                    "authenticationType": "AadServicePrincipal",
                    "servicePrincipalId": "[parameters('servicePrincipalId')]",
                    "servicePrincipalKey": {
                        "type": "AzureKeyVaultSecret",
                        "store": {
                            "referenceName": "LS_AzureKeyVault",
                            "type": "LinkedServiceReference"
                        },
                        "secretName": "[parameters('clientSecretSecretName')]"
                    },
                    "tenant": "[parameters('tenantId')]",
                    "aadResourceId": "[concat(parameters('sharePointTenantUrl'), '/')]",
                    "azureCloudType": "AzurePublic"
                }
            }
        },
        {
            "name": "[concat(parameters('factoryName'), '/LS_SharePointOnline_HTTP')]",
            "type": "Microsoft.DataFactory/factories/linkedServices",
            "apiVersion": "2018-06-01",
            "dependsOn": [
                "[variables('factoryId')]"
            ],
            "properties": {
                "description": "HTTP linked service for SharePoint file downloads",
                "annotations": ["sharepoint", "source", "file-download", "hydro-one-migration"],
                "type": "HttpServer",
                "typeProperties": {
                    "url": "[parameters('sharePointTenantUrl')]",
                    "enableServerCertificateValidation": true,
                    "authenticationType": "Anonymous"
                }
            }
        },
        {
            "name": "[concat(parameters('factoryName'), '/LS_ADLS_Gen2')]",
            "type": "Microsoft.DataFactory/factories/linkedServices",
            "apiVersion": "2018-06-01",
            "dependsOn": [
                "[variables('factoryId')]"
            ],
            "properties": {
                "description": "ADLS Gen2 linked service using Managed Identity",
                "annotations": ["adls", "sink", "managed-identity", "hydro-one-migration"],
                "type": "AzureBlobFS",
                "typeProperties": {
                    "url": "[concat('https://', parameters('storageAccountName'), '.dfs.core.windows.net/')]"
                }
            }
        },
        {
            "name": "[concat(parameters('factoryName'), '/LS_AzureSqlDatabase')]",
            "type": "Microsoft.DataFactory/factories/linkedServices",
            "apiVersion": "2018-06-01",
            "dependsOn": [
                "[variables('factoryId')]"
            ],
            "properties": {
                "description": "Azure SQL Database for migration control and audit tables",
                "annotations": ["sql", "control-table", "audit-log", "hydro-one-migration"],
                "type": "AzureSqlDatabase",
                "typeProperties": {
                    "connectionString": "[concat('Server=tcp:', parameters('sqlServerName'), '.database.windows.net,1433;Initial Catalog=', parameters('sqlDatabaseName'), ';')]",
                    "authenticationType": "ManagedIdentity"
                }
            }
        },
        {
            "name": "[concat(parameters('factoryName'), '/DS_SQL_MigrationControl')]",
            "type": "Microsoft.DataFactory/factories/datasets",
            "apiVersion": "2018-06-01",
            "dependsOn": [
                "[variables('factoryId')]",
                "[concat(variables('factoryId'), '/linkedServices/LS_AzureSqlDatabase')]"
            ],
            "properties": {
                "description": "Migration control table dataset",
                "linkedServiceName": {
                    "referenceName": "LS_AzureSqlDatabase",
                    "type": "LinkedServiceReference"
                },
                "annotations": ["sql", "control-table", "hydro-one-migration"],
                "parameters": {
                    "SchemaName": { "type": "string", "defaultValue": "dbo" },
                    "TableName": { "type": "string", "defaultValue": "MigrationControl" }
                },
                "type": "AzureSqlTable",
                "typeProperties": {
                    "schema": { "value": "@dataset().SchemaName", "type": "Expression" },
                    "table": { "value": "@dataset().TableName", "type": "Expression" }
                }
            }
        },
        {
            "name": "[concat(parameters('factoryName'), '/DS_SQL_AuditLog')]",
            "type": "Microsoft.DataFactory/factories/datasets",
            "apiVersion": "2018-06-01",
            "dependsOn": [
                "[variables('factoryId')]",
                "[concat(variables('factoryId'), '/linkedServices/LS_AzureSqlDatabase')]"
            ],
            "properties": {
                "description": "Migration audit log dataset",
                "linkedServiceName": {
                    "referenceName": "LS_AzureSqlDatabase",
                    "type": "LinkedServiceReference"
                },
                "annotations": ["sql", "audit-log", "hydro-one-migration"],
                "parameters": {
                    "SchemaName": { "type": "string", "defaultValue": "dbo" },
                    "TableName": { "type": "string", "defaultValue": "MigrationAuditLog" }
                },
                "type": "AzureSqlTable",
                "typeProperties": {
                    "schema": { "value": "@dataset().SchemaName", "type": "Expression" },
                    "table": { "value": "@dataset().TableName", "type": "Expression" }
                }
            }
        },
        {
            "name": "[concat(parameters('factoryName'), '/DS_ADLS_Binary_Sink')]",
            "type": "Microsoft.DataFactory/factories/datasets",
            "apiVersion": "2018-06-01",
            "dependsOn": [
                "[variables('factoryId')]",
                "[concat(variables('factoryId'), '/linkedServices/LS_ADLS_Gen2')]"
            ],
            "properties": {
                "description": "Binary sink dataset for ADLS Gen2",
                "linkedServiceName": {
                    "referenceName": "LS_ADLS_Gen2",
                    "type": "LinkedServiceReference"
                },
                "annotations": ["adls", "sink", "binary", "hydro-one-migration"],
                "parameters": {
                    "ContainerName": { "type": "string", "defaultValue": "sharepoint-migration" },
                    "SiteName": { "type": "string" },
                    "LibraryName": { "type": "string" },
                    "FolderPath": { "type": "string", "defaultValue": "" },
                    "FileName": { "type": "string" }
                },
                "type": "Binary",
                "typeProperties": {
                    "location": {
                        "type": "AzureBlobFSLocation",
                        "fileName": { "value": "@dataset().FileName", "type": "Expression" },
                        "folderPath": { "value": "@concat(dataset().SiteName, '/', dataset().LibraryName, if(empty(dataset().FolderPath), '', concat('/', dataset().FolderPath)))", "type": "Expression" },
                        "fileSystem": { "value": "@dataset().ContainerName", "type": "Expression" }
                    }
                }
            }
        },
        {
            "name": "[concat(parameters('factoryName'), '/DS_SharePoint_Binary_HTTP')]",
            "type": "Microsoft.DataFactory/factories/datasets",
            "apiVersion": "2018-06-01",
            "dependsOn": [
                "[variables('factoryId')]",
                "[concat(variables('factoryId'), '/linkedServices/LS_SharePointOnline_HTTP')]"
            ],
            "properties": {
                "description": "Binary HTTP dataset for SharePoint file downloads",
                "linkedServiceName": {
                    "referenceName": "LS_SharePointOnline_HTTP",
                    "type": "LinkedServiceReference"
                },
                "annotations": ["sharepoint", "binary", "source", "hydro-one-migration"],
                "parameters": {
                    "FileUrl": { "type": "string" }
                },
                "type": "Binary",
                "typeProperties": {
                    "location": {
                        "type": "HttpServerLocation",
                        "relativeUrl": { "value": "@dataset().FileUrl", "type": "Expression" }
                    }
                }
            }
        },
        {
            "name": "[concat(parameters('factoryName'), '/DS_ADLS_Parquet_Metadata')]",
            "type": "Microsoft.DataFactory/factories/datasets",
            "apiVersion": "2018-06-01",
            "dependsOn": [
                "[variables('factoryId')]",
                "[concat(variables('factoryId'), '/linkedServices/LS_ADLS_Gen2')]"
            ],
            "properties": {
                "description": "Parquet dataset for metadata storage",
                "linkedServiceName": {
                    "referenceName": "LS_ADLS_Gen2",
                    "type": "LinkedServiceReference"
                },
                "annotations": ["adls", "metadata", "parquet", "hydro-one-migration"],
                "parameters": {
                    "ContainerName": { "type": "string", "defaultValue": "migration-metadata" },
                    "FolderPath": { "type": "string", "defaultValue": "file-inventory" }
                },
                "type": "Parquet",
                "typeProperties": {
                    "location": {
                        "type": "AzureBlobFSLocation",
                        "folderPath": { "value": "@dataset().FolderPath", "type": "Expression" },
                        "fileSystem": { "value": "@dataset().ContainerName", "type": "Expression" }
                    },
                    "compressionCodec": "snappy"
                }
            }
        }
    ],
    "outputs": {
        "dataFactoryName": {
            "type": "string",
            "value": "[parameters('factoryName')]"
        },
        "dataFactoryPrincipalId": {
            "type": "string",
            "value": "[reference(variables('factoryId'), '2018-06-01', 'Full').identity.principalId]"
        },
        "dataFactoryTenantId": {
            "type": "string",
            "value": "[reference(variables('factoryId'), '2018-06-01', 'Full').identity.tenantId]"
        }
    }
}
